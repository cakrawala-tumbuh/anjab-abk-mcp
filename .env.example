# Contoh konfigurasi ANJAB-ABK MCP Server. Salin menjadi .env dan isi nilainya.

# ── Server ────────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=ANJAB-ABK MCP
MCP_LOG_LEVEL=INFO

# Transport saat `python -m anjab_abk_mcp` (stdio | http | sse).
# Untuk Docker/cloud, uvicorn memakai anjab_abk_mcp.asgi:app (lihat Dockerfile).
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# ── Backend ───────────────────────────────────────────────────────────────────
# URL base anjab-abk-backend. Contoh: https://api.anjab.example.com
BACKEND_BASE_URL=http://localhost:8001

# Token Authentik statis untuk mode stdio/API key (service account).
# Dipakai bila tidak ada token user dari OAuth (mis. Claude Code stdio).
# Kosongkan untuk menonaktifkan akses backend di mode non-OAuth.
BACKEND_API_TOKEN=

# ── OAuth via Authentik (WAJIB untuk Claude Web / claude.ai) ──────────────────
# URL publik MCP server ini (untuk redirect OAuth). Contoh: https://mcp.anjab.example.com
MCP_BASE_URL=

# Pola B: issuer URL SAMA dengan yang dikonfigurasi di anjab-abk-backend.
# Format: https://auth.example.com/application/o/<app-slug>/
AUTHENTIK_ISSUER_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# preferred_username yang diizinkan. Format: comma-separated (user1,user2),
# nilai tunggal (user1), atau JSON array (["user1","user2"]). Kosong = semua diizinkan.
AUTHENTIK_ALLOWED_USERNAMES=

# ── API Key (klien non-OAuth: VS Code / CLI) ──────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Kosongkan untuk menonaktifkan (lokal/stdio).
MCP_API_KEY=
