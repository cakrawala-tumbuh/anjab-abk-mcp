# Image untuk automated test (lint + unit). BUKAN image runtime.
#
# Source di-COPY ke dalam image (BUKAN bind-mount). Konsekuensinya:
#  - Test berjalan terisolasi; hasil sama di mesin developer manapun dan di CI.
#  - Artefak test (__pycache__, .pytest_cache, dll) hidup di dalam container
#    dan ikut terhapus saat `docker run --rm`. Folder project di host tetap bersih.
#
# Pin Python 3.12-slim untuk parity lokal vs CI.
FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install dependency aplikasi dari pyproject.toml + tooling test (versi dipin).
# Urutan ini mengoptimalkan cache layer Docker: deps jarang berubah, source sering.
COPY pyproject.toml README.md requirements-test.txt ./
COPY src ./src
RUN pip install --no-cache-dir . \
    && pip install --no-cache-dir -r requirements-test.txt

# Copy seluruh source termasuk tests/ (pengecualian diatur di .dockerignore).
COPY . .
